<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.OfflineUPI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_indigo</item>
        <item name="colorPrimaryVariant">@color/accent_indigo_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="27">shortEdges</item>
    </style>

    <!-- Scanner overlay theme (fully dark status bar) -->
    <style name="Theme.OfflineUPI.Scanner" parent="Theme.OfflineUPI">
        <item name="android:windowBackground">@color/bg_scanner</item>
        <item name="android:statusBarColor">@color/bg_scanner</item>
    </style>
</resources>
