<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top bar: title + balance pill -->
    <TextView
        android:id="@+id/tvHomeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payments"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp" />

    <LinearLayout
        android:id="@+id/balancePill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_input_pill"
        android:paddingHorizontal="12dp"
        android:paddingVertical="7dp"
        app:layout_constraintTop_toTopOf="@id/tvHomeTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvHomeTitle"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="20dp">

        <TextView
            android:id="@+id/tvBalancePill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Balance"
            android:textColor="@color/text_secondary_light"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <ImageView
            android:id="@+id/ivBalanceEye"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_visibility_off"
            app:tint="@color/text_secondary"
            android:layout_marginStart="6dp"
            android:contentDescription="Toggle balance" />
    </LinearLayout>

    <!-- Section label -->
    <TextView
        android:id="@+id/tvFeedLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RECENT ACTIVITY"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/tvHomeTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="14dp"
        android:layout_marginStart="20dp" />

    <!-- Ledger feed -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFeed"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvFeedLabel"
        app:layout_constraintBottom_toTopOf="@id/dock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvFeedLabel"
        app:layout_constraintBottom_toTopOf="@id/dock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No payments yet"
            android:textColor="@color/text_secondary_light"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan a QR or enter a number below to pay"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Pay dock -->
    <LinearLayout
        android:id="@+id/dock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:focusableInTouchMode="true"
        android:background="@drawable/bg_dock"
        android:paddingTop="10dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/card_stroke" />

        <!-- Recents (wrapped so its horizontal scroll doesn't fight tab swipes) -->
        <com.offlineupi.app.ui.NestedScrollableHost
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:clipToPadding="false"
                android:paddingVertical="12dp" />
        </com.offlineupi.app.ui.NestedScrollableHost>

        <!-- Pay row: [Scan QR][Number / UPI ID] morphs in place — Scan QR shrinks
             to a square QR icon (corners intact, label hides), the pill becomes
             the input, and Pay grows in at the end. One width animator. -->
        <LinearLayout
            android:id="@+id/payRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:clipChildren="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanQr"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:text="Scan QR"
                android:textSize="14sp"
                android:textColor="@color/on_accent"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="0dp"
                app:backgroundTint="@color/accent_emerald"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_qr_scan"
                app:iconGravity="textStart"
                app:iconTint="@color/on_accent"
                app:iconPadding="6dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btnToId"
                android:foreground="@drawable/ripple_pill"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="Number / UPI ID"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_input_pill"
                android:paddingHorizontal="14dp"
                android:drawablePadding="6dp"
                app:drawableStartCompat="@drawable/ic_dialpad"
                android:drawableTint="@color/text_primary" />

            <EditText
                android:id="@+id/etPayeeInput"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:hint="Phone or UPI ID"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:inputType="phone"
                android:imeOptions="actionGo"
                android:maxLines="1"
                android:background="@drawable/bg_input_pill"
                android:paddingHorizontal="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:id="@+id/btnKbToggle"
                android:foreground="@drawable/ripple_pill"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="ABC"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:background="@drawable/bg_input_pill" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPayGo"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:paddingHorizontal="0dp"
                android:text="Pay"
                android:textSize="14sp"
                android:textColor="@color/on_accent"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="@color/accent_emerald"
                app:cornerRadius="14dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="14dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
