<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_detail_group"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <View
            android:id="@+id/tileDot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_pill_active" />
        <TextView
            android:id="@+id/tileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tileValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:layout_marginTop="4dp" />

    <com.offlineupi.app.ui.charts.SparkView
        android:id="@+id/tileSpark"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:layout_marginTop="4dp"
        android:alpha="0.85" />

    <TextView
        android:id="@+id/tileDay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />
</LinearLayout>
