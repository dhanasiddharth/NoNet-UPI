<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Money"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PORTFOLIO VALUE"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 12,48,730"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲ ₹15,290 · 1.24% today"
                android:textColor="@color/accent_green"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:src="@drawable/img_demo_chart"
                android:scaleType="fitXY"
                android:contentDescription="Demo portfolio chart"
                android:layout_marginTop="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:weightSum="6">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="1D" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" android:paddingVertical="6dp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="1W" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" android:paddingVertical="6dp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="1M" android:gravity="center" android:textColor="@color/accent_emerald_light" android:textSize="11sp" android:textStyle="bold" android:background="@drawable/bg_pill_active" android:paddingVertical="6dp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="3M" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" android:paddingVertical="6dp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="1Y" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" android:paddingVertical="6dp" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="All" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" android:paddingVertical="6dp" />
            </LinearLayout>

            <!-- Coming soon card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_detail_group"
                android:padding="18dp"
                android:layout_marginTop="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coming soon"
                    android:textColor="@color/accent_emerald_light"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your Yahoo Finance portfolio will sync here — holdings, sparklines, and 1D–1Y performance. The chart above is a preview of the layout."
                    android:textColor="@color/text_secondary_light"
                    android:textSize="13.5sp"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
