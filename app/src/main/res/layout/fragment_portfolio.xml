<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Money"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvSyncStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11.5sp"
                    android:background="@drawable/bg_input_pill"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginEnd="4dp" />
                <ImageButton
                    android:id="@+id/btnAlerts"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_bell"
                    android:background="@drawable/ripple_pill"
                    android:contentDescription="Alerts"
                    app:tint="@color/text_secondary" />
                <ImageButton
                    android:id="@+id/btnSync"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_refresh_sync"
                    android:background="@drawable/ripple_pill"
                    android:contentDescription="Sync"
                    app:tint="@color/accent_emerald_light" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13.5sp"
                android:lineSpacingExtra="3dp"
                android:paddingVertical="28dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PORTFOLIO"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="16dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvHeroValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02" />
                    <ImageButton
                        android:id="@+id/btnEye"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_visibility"
                        android:background="@drawable/ripple_pill"
                        android:contentDescription="Hide values"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <TextView
                        android:id="@+id/tvDayChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12.5sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="3dp" />
                    <TextView
                        android:id="@+id/tvXirrChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12.5sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_input_pill"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="3dp"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
                <TextView
                    android:id="@+id/tvHeroSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12.5sp"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:id="@+id/layoutTiles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="22dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="PERFORMANCE"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                    <LinearLayout
                        android:id="@+id/layoutChartMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                    <TextView
                        android:id="@+id/btnCompare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="vs index"
                        android:textColor="@color/text_secondary"
                        android:textSize="11.5sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_input_pill"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginStart="6dp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/layoutRanges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">
                    <TextView
                        android:id="@+id/tvRangeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvRangeChange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:layout_marginStart="8dp" />
                    <TextView
                        android:id="@+id/tvRangeMeta"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textColor="@color/text_secondary"
                        android:textSize="11.5sp" />
                </LinearLayout>
                <com.offlineupi.app.ui.charts.LineChartView
                    android:id="@+id/chart"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_marginTop="6dp" />
                <TextView
                    android:id="@+id/tvLegend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />

                <View style="@style/PortfolioDivider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEATING THE MARKET &amp; INFLATION?"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● you   ○ index   ▎inflation"
                    android:textColor="@color/text_secondary"
                    android:textSize="10.5sp"
                    android:layout_marginTop="4dp" />
                <com.offlineupi.app.ui.charts.DotPlotView
                    android:id="@+id/dotPlot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />
                <TextView
                    android:id="@+id/tvBeatFooter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11.5sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="8dp" />

                <View style="@style/PortfolioDivider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="ALLOCATION"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/tvAllocTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="11.5sp" />
                    <TextView
                        android:id="@+id/tvAllocZoom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zoom ›"
                        android:textColor="@color/accent_emerald_light"
                        android:textSize="11.5sp"
                        android:textStyle="bold"
                        android:background="@drawable/ripple_group"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/allocBar"
                    android:layout_width="match_parent"
                    android:layout_height="14dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp" />
                <LinearLayout
                    android:id="@+id/allocKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp" />

                <View style="@style/PortfolioDivider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="MOVEMENT"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/tvMoversAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All ›"
                        android:textColor="@color/accent_emerald_light"
                        android:textSize="11.5sp"
                        android:textStyle="bold"
                        android:background="@drawable/ripple_group"
                        android:paddingHorizontal="6dp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/layoutMovers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp" />

                <View style="@style/PortfolioDivider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="TOP HOLDINGS"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/tvHoldingsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="11.5sp" />
                    <TextView
                        android:id="@+id/tvHoldingsAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All ›"
                        android:textColor="@color/accent_emerald_light"
                        android:textSize="11.5sp"
                        android:textStyle="bold"
                        android:background="@drawable/ripple_group"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/layoutHoldings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
