<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Account balances -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BALANCES"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="18dp" />

            <LinearLayout
                android:id="@+id/layoutBalances"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_detail_group"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvNoBalances"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No balances yet — run a check below."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:background="@drawable/bg_detail_group"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMissedCall"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Missed call"
                    android:textSize="13sp"
                    android:textColor="@color/accent_emerald_light"
                    android:fontFamily="sans-serif-medium"
                    app:icon="@drawable/ic_phone_missed"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="@color/accent_emerald_light"
                    app:strokeColor="@color/card_stroke"
                    app:cornerRadius="14dp"
                    android:layout_marginEnd="5dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUssdCheck"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="USSD (*99#)"
                    android:textSize="13sp"
                    android:textColor="@color/accent_emerald_light"
                    android:fontFamily="sans-serif-medium"
                    app:icon="@drawable/ic_dialpad"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="@color/accent_emerald_light"
                    app:strokeColor="@color/card_stroke"
                    app:cornerRadius="14dp"
                    android:layout_marginStart="5dp" />

            </LinearLayout>

            <!-- In / Out / Reconciled -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_detail_group" android:padding="12dp" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IN" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.08" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹ 1,84,000" android:textColor="@color/accent_green" android:textSize="15sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_detail_group" android:padding="12dp" android:layout_marginHorizontal="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OUT" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.08" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹ 92,410" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_detail_group" android:padding="12dp" android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RECONCILED" android:textColor="@color/text_secondary" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.08" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="96%" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Coming soon card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_detail_group"
                android:padding="18dp"
                android:layout_marginTop="18dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coming soon"
                    android:textColor="@color/accent_emerald_light"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bank statements will load here and auto-reconcile against your UPI payments by RRN. Categorize expenses in a review inbox and attach invoices or bills to any transaction. The tiles above preview the monthly summary."
                    android:textColor="@color/text_secondary_light"
                    android:textSize="13.5sp"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Sample rows -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PREVIEW"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="20dp" android:layout_marginBottom="4dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp" android:padding="11dp" android:src="@drawable/ic_cart" app:tint="@color/text_secondary" android:contentDescription="@null" android:background="@drawable/bg_detail_group" android:layout_marginEnd="12dp" />
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ratnadeep Super Market" android:textColor="@color/text_primary" android:textSize="14.5sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Groceries · matched RRN ··1607" android:textColor="@color/accent_green" android:textSize="11.5sp" android:layout_marginTop="1dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="− ₹2,340" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp" android:padding="11dp" android:src="@drawable/ic_help" app:tint="@color/accent_amber" android:contentDescription="@null" android:background="@drawable/bg_detail_group" android:layout_marginEnd="12dp" />
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ATM WDL 6201" android:textColor="@color/text_primary" android:textSize="14.5sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tap to categorize" android:textColor="@color/accent_emerald_light" android:textSize="11.5sp" android:layout_marginTop="1dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="− ₹5,000" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
