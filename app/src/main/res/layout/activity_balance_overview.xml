<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_dark"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/text_primary"
            app:title="Account Balances"
            app:titleTextColor="@color/text_primary"
            app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="80dp"
            android:paddingHorizontal="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No balance data yet"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:textAlignment="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap the button below to check balances via missed call"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textAlignment="center"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Balance list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvBalances"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp" />

        <!-- Last updated info -->
        <TextView
            android:id="@+id/tvLastUpdated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textAlignment="center"
            android:paddingHorizontal="16dp"
            android:visibility="gone" />

        <!-- Check via Missed Call -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckBalance"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Check via Missed Call"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/accent_indigo"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_dialpad"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp" />

        <!-- Check via USSD -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckUssd"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Check via USSD (*99#)"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/card_bg"
            app:strokeColor="@color/accent_indigo"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_account_balance"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/accent_indigo"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
