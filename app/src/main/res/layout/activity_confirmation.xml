<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="28dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/confirm_title"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- Pay-to + amount card: avatar, name, editable address, hero amount -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp"
            android:layout_marginTop="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="26dp">

                <!-- Avatar -->
                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="@color/accent_emerald_light"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_avatar_emerald" />

                <!-- Payee name -->
                <TextView
                    android:id="@+id/tvPayeeName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textAlignment="center"
                    android:layout_marginTop="14dp" />

                <!-- Editable address (QR payees can be corrected; long-press = copy) -->
                <EditText
                    android:id="@+id/tvUpiId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:inputType="textEmailAddress|textNoSuggestions"
                    android:importantForAutofill="no"
                    android:maxLines="1"
                    android:gravity="center"
                    android:textColor="@color/accent_emerald_light"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />

                <!-- Amount label -->
                <TextView
                    android:id="@+id/tvAmountLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_amount"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="22dp" />

                <!-- Static amount (QR carried an amount) -->
                <TextView
                    android:id="@+id/tvAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <!-- Amount entry (no amount yet) — ₹ + big editable number -->
                <LinearLayout
                    android:id="@+id/layoutAmountEntry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹"
                        android:textColor="@color/text_secondary"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="4dp" />

                    <EditText
                        android:id="@+id/etAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:minWidth="64dp"
                        android:hint="0"
                        android:textColorHint="@color/text_secondary"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:importantForAutofill="no" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAmountError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_red"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recent payments with this payee (shown when there's history) -->
        <TextView
            android:id="@+id/tvRecentLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RECENT PAYMENTS"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginTop="24dp"
            android:layout_marginStart="4dp"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRecent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layoutRecent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Remarks -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRemarks"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Remarks (optional)"
            app:boxStrokeColor="@color/accent_emerald"
            app:hintTextColor="@color/text_secondary"
            android:layout_marginTop="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRemarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Security notice -->
        <TextView
            android:id="@+id/tvSecurityNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/confirm_security_note"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAlignment="center"
            android:drawablePadding="4dp"
            android:layout_marginTop="18dp" />

        <!-- Pay via USSD button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayUssd"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_pay_ussd"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/accent_emerald"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_dialpad"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            android:layout_marginTop="20dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
