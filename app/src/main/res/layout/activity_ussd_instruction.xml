<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="28dp">

        <!-- Header: Paying <name>  ·  Amount ₹x -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAYING"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvPayingName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AMOUNT"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvPayingAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Live status line -->
        <TextView
            android:id="@+id/tvUssdSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvClipboardBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_emerald_light"
            android:textSize="11.5sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_chip_verified"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

        <!-- Timeline: five outcome steps -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_detail_group"
            android:padding="16dp"
            android:layout_marginTop="18dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="7dp">
                <TextView android:id="@+id/tvStep1Status" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:background="@drawable/bg_step_pending" android:textColor="@color/text_secondary" android:layout_marginEnd="12dp" />
                <TextView android:id="@+id/tvStep1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:lineSpacingExtra="1dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="7dp">
                <TextView android:id="@+id/tvStep2Status" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:background="@drawable/bg_step_pending" android:textColor="@color/text_secondary" android:layout_marginEnd="12dp" />
                <TextView android:id="@+id/tvStep2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:lineSpacingExtra="1dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="7dp">
                <TextView android:id="@+id/tvStep3Status" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:background="@drawable/bg_step_pending" android:textColor="@color/text_secondary" android:layout_marginEnd="12dp" />
                <TextView android:id="@+id/tvStep3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:lineSpacingExtra="1dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="7dp">
                <TextView android:id="@+id/tvStep4Status" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:background="@drawable/bg_step_pending" android:textColor="@color/text_secondary" android:layout_marginEnd="12dp" />
                <TextView android:id="@+id/tvStep4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:lineSpacingExtra="1dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="7dp">
                <TextView android:id="@+id/tvStep5Status" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:background="@drawable/bg_step_pending" android:textColor="@color/text_secondary" android:layout_marginEnd="12dp" />
                <TextView android:id="@+id/tvStep5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="13.5sp" android:fontFamily="sans-serif-medium" android:lineSpacingExtra="1dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Verification trust card -->
        <TextView
            android:id="@+id/tvSecurityNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12.5sp"
            android:lineSpacingExtra="3dp"
            android:background="@drawable/bg_detail_group"
            android:padding="16dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvDisclaimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

        <!-- Location tag: reverse-geocoded place picker (populated at runtime) -->
        <LinearLayout
            android:id="@+id/layoutLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_detail_group"
            android:padding="16dp"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvLocationHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WHERE ARE YOU PAYING?"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tvLocationStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12.5sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="6dp" />

            <LinearLayout
                android:id="@+id/layoutPlaceList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Result block -->
        <LinearLayout
            android:id="@+id/layoutResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <View
                android:id="@+id/dividerResult"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp" />

            <TextView
                android:id="@+id/tvResultDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12.5sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckStatus"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/btn_check_status"
            android:textSize="14sp"
            android:textColor="@color/accent_emerald_light"
            app:strokeColor="@color/card_stroke"
            app:cornerRadius="14dp"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/btn_retry_transaction"
            android:textSize="14sp"
            android:textColor="@color/on_accent"
            app:backgroundTint="@color/accent_emerald"
            app:cornerRadius="14dp"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/btn_done_verify_background"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            app:strokeColor="@color/card_stroke"
            app:cornerRadius="14dp"
            android:layout_marginTop="10dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
