<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="32dp">

        <!-- Icon -->
        <ImageView
            android:id="@+id/ivUssdIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_dialpad"
            android:contentDescription="@null"
            app:tint="@color/accent_indigo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvUssdTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ussd_title"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toBottomOf="@id/ivUssdIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvUssdSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/ussd_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvUssdTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <!-- Instructions Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInstructions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/tvUssdSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Step 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tvStep1Status"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_step_pending"
                        android:text="1"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvStep1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" />

                <!-- Step 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvStep2Status"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_step_pending"
                        android:text="2"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvStep2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>

                <!-- Clipboard copied badge -->
                <TextView
                    android:id="@+id/tvClipboardBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_green"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_green"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:layout_marginBottom="20dp"
                    android:visibility="gone" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" />

                <!-- Step 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tvStep3Status"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_step_pending"
                        android:text="3"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvStep3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" />

                <!-- Step 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tvStep4Status"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_step_pending"
                        android:text="4"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvStep4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" />

                <!-- Step 5 (PIN - manual) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp">

                    <TextView
                        android:id="@+id/tvStep5Status"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_step_pending"
                        android:text="5"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvStep5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- SMS Disclaimer -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDisclaimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/disclaimer_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/cardInstructions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/tvDisclaimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_amber"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:padding="16dp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Security note -->
        <TextView
            android:id="@+id/tvSecurityNote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAlignment="center"
            android:lineSpacingExtra="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardDisclaimer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <!-- Done Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/btn_done"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/card_bg"
            app:strokeColor="@color/accent_indigo"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvSecurityNote"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
