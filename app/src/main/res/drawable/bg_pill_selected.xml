<?xml version="1.0" encoding="utf-8"?>
<!-- Selected chip/filter: same geometry as bg_input_pill so selection never
     shifts shape — only fill and stroke change. Deep emerald fill keeps
     accent_emerald_light text at ~7:1 contrast. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="#123324" />
    <corners android:radius="14dp" />
    <stroke android:width="1dp" android:color="@color/accent_emerald" />
</shape>
