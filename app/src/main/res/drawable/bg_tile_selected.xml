<?xml version="1.0" encoding="utf-8"?>
<!-- Selected bucket tile: keeps bg_detail_group's 16dp geometry, adds the
     emerald selected treatment so selection reads as state, not a glitch. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/pill_selected_fill" />
    <corners android:radius="16dp" />
    <stroke android:width="1dp" android:color="@color/accent_emerald" />
</shape>
